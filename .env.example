# Copy to .env and fill in. .env is gitignored.

# --- Postgres (compose `db` service) ---
POSTGRES_USER=rbga
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rbga

# How the api/bot reach Postgres. Host is the compose service name `db`.
DATABASE_URL=postgresql+psycopg://rbga:change-me@db:5432/rbga

# Complaints isolation (Postgres only). Give complaints their own schema, and
# in production their own DB role/credentials. Leave blank for SQLite dev.
COMPLAINTS_SCHEMA=complaints

# Token required to READ complaints (GET /complaints). Submitting is public.
COMPLAINTS_API_TOKEN=generate-a-long-random-string

# --- Discord bot ---
DISCORD_TOKEN=your-bot-token
# Optional: a guild id makes slash commands appear instantly (global sync is slow).
DISCORD_GUILD_ID=
