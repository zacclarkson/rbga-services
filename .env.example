# Copy to .env and fill in. .env is gitignored.

# --- Postgres (compose `db` service) ---
POSTGRES_USER=rbga
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rbga

# How the api/bot reach Postgres. Host is the compose service name `db`.
DATABASE_URL=postgresql+psycopg://rbga:change-me@db:5432/rbga

# Complaints isolation (Postgres only). Give complaints their own schema, and
# in production their own DB role/credentials. Leave blank for SQLite dev.
COMPLAINTS_SCHEMA=complaints

# Token required to READ + MANAGE complaints (GET/PATCH /complaints). Submitting
# is public. Kept separate from RBGA_API_TOKEN so a leak of the general write
# token can't reach complaints.
COMPLAINTS_API_TOKEN=generate-a-long-random-string

# Days to keep a complaint after it is CLOSED before the retention purge deletes
# it (rbga.db.purge_complaints, policy §8). Leave blank to disable purging
# entirely (fail-safe — nothing is deleted). The exec owns this number.
COMPLAINTS_RETENTION_DAYS=

# Token required for REST WRITES on keys + board games (POST/DELETE), sent as the
# X-API-Token header. Reads stay open. Leave blank to deny all writes (fail
# closed). Discord mutations are gated separately by DISCORD_KEYS_ROLE.
RBGA_API_TOKEN=generate-a-long-random-string

# Comma-separated origins allowed to call the API cross-origin (for the complaints
# form on GitHub Pages). Leave blank until the form ships (no cross-origin allowed).
# e.g. CORS_ALLOW_ORIGINS=https://rmitboardgames.github.io
CORS_ALLOW_ORIGINS=

# --- Discord bot ---
DISCORD_TOKEN=your-bot-token
# Optional: a guild id makes slash commands appear instantly (global sync is slow).
DISCORD_GUILD_ID=
# Name of the exec role allowed to run ALL bot mutations: keys (/take, /return,
# /addkey, /removekey) and board games (/game add|edit|remove). Reads/lookups stay
# open to everyone. Leave blank to deny all mutations (fail closed).
DISCORD_KEYS_ROLE=Exec

# BoardGameGeek XML API token, for /game add auto-fill from a BGG link. BGG now
# requires a per-app Bearer token (register at https://boardgamegeek.com/api).
# Leave blank to disable BGG lookups (manual /game add still works).
BGG_API_TOKEN=
